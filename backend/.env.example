NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://127.0.0.1:27017/scientific_trend_tracker

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

CLIENT_URL=http://localhost:5173

OPENALEX_BASE_URL=https://api.openalex.org
OPENALEX_CONTACT_EMAIL=your_email@example.com
OPENALEX_ENABLED=false

CROSSREF_BASE_URL=https://api.crossref.org
CROSSREF_MAILTO=your_email@example.com
CROSSREF_ENABLED=false

SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_ENABLED=true

SYNC_CRON=0 2 * * *
DEFAULT_SYNC_KEYWORDS=artificial intelligence,machine learning,deep learning,natural language processing,computer vision,software engineering,cybersecurity
