#!/usr/bin/env node

require("dotenv").config();

const http = require("http");
const app = require("../app");
const connectDB = require("../config/db");
const { startSyncJob } = require("../jobs/sync.job");

const normalizePort = (value) => {
  const port = parseInt(value, 10);
  if (Number.isNaN(port)) return value;
  if (port >= 0) return port;
  return false;
};

const port = normalizePort(process.env.PORT || "5000");
app.set("port", port);

const server = http.createServer(app);

connectDB()
  .then(() => {
    startSyncJob();
    server.listen(port);
  })
  .catch((error) => {
    console.error("Database connection failed:", error.message);
    process.exit(1);
  });

server.on("error", (error) => {
  if (error.syscall !== "listen") throw error;
  const bind = typeof port === "string" ? `Pipe ${port}` : `Port ${port}`;
  if (error.code === "EACCES") console.error(`${bind} requires elevated privileges`);
  else if (error.code === "EADDRINUSE") console.error(`${bind} is already in use`);
  else throw error;
  process.exit(1);
});

server.on("listening", () => {
  const addr = server.address();
  const bind = typeof addr === "string" ? `pipe ${addr}` : `port ${addr.port}`;
  console.log(`API listening on ${bind}`);
});
